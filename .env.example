# ──────────────────────────────────────────────────────────────────────────────
# Livia — environment variables
#
# You normally DON'T need this file: run the app and complete the web wizard at
# /setup, which writes everything to setup.json for you. This file is for people
# who prefer to configure via environment variables (e.g. on a PaaS) instead.
#
# Copy to ".env" and fill in. Anything set in setup.json takes precedence.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # Your Anthropic API key — https://console.anthropic.com
GOOGLE_CLIENT_ID=           # Google OAuth client ID — Google Cloud Console
GOOGLE_CLIENT_SECRET=       # Google OAuth client secret
GOOGLE_REFRESH_TOKEN=       # Obtained via /auth/login (or the wizard saves it for you)
OWNER_EMAILS=               # Comma-separated owner emails, e.g. you@work.com,you@home.com
OWNER_EMAIL=                # Your primary email (default From/To)
OWNER_NAME=                 # Your name — used in greetings, signature, and prompts
LIVIA_EMAIL=                # The assistant's dedicated Gmail address

# ── Recommended ──────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=         # Protects the dashboard — set this or the API stays locked
ALLOWED_ORIGINS=            # Comma-separated allowed origins for CORS, e.g. https://your-app.example.com
GOOGLE_REDIRECT_URI=        # OAuth redirect, e.g. http://localhost:3000/auth/callback

# ── Optional ─────────────────────────────────────────────────────────────────
ORG_NAME=                   # Brand/organisation name shown in the UI
LIVIA_NAME=                 # Assistant display name (defaults to "Livia")
TIMEZONE=                   # IANA timezone for scheduling, e.g. America/New_York (defaults to UTC)
OWNER_PHONE=                # Your phone with country code, e.g. +1 555 123 4567
OWNER_CALENDAR_EMAIL=       # Calendar account email (defaults to OWNER_EMAIL)
GOOGLE_CALENDAR_REFRESH_TOKEN=  # Owner calendar token — via /auth/calendar-login
GOOGLE_CONTACTS_REFRESH_TOKEN=  # Contacts token — via /auth/contacts-login (CRM sync)
TELEGRAM_BOT_TOKEN=         # From @BotFather — enables two-way Telegram chat
TELEGRAM_CHAT_ID=           # Auto-detected on first message; set to persist
POLL_INTERVAL=1             # Inbox poll interval in minutes (default 1)
DEPLOY_ID=                  # Bump to force a clean state wipe on redeploy
PORT=3000                   # HTTP port (default 3000)
